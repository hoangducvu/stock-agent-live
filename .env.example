# ─── Alpaca API Keys ────────────────────────────────────────
# Sign up at https://alpaca.markets and generate API keys
# Use PAPER keys first to test, then switch to LIVE when ready
APCA_API_KEY_ID=YOUR_API_KEY_HERE
APCA_API_SECRET_KEY=YOUR_API_SECRET_HERE

# ─── Trading Mode ───────────────────────────────────────────
# "paper" = fake money, safe testing (start here!)
# "live"  = real money, real trades
TRADING_MODE=paper

# ─── Safety Controls ────────────────────────────────────────
# Set to "true" to immediately close all positions and shut down
KILL_SWITCH=false

# Set to "true" to close all positions on Ctrl+C / shutdown
# Set to "false" to leave positions open (swing trades survive restarts)
CLOSE_ON_SHUTDOWN=true

# ─── Slack Integration ───────────────────────────────────────
# Bot Token (starts with xoxb-) — from OAuth & Permissions page
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
# App-Level Token (starts with xapp-) — from Basic Information > App-Level Tokens
SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN

# ─── Claude AI (for natural language Q&A in Slack) ──────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
